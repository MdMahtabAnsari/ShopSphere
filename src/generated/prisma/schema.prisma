// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  name              String
  email             String              @unique
  phone             String              @unique
  password          String
  role              UserRole[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  addresses         UserAddress[]
  UserPaymentMethod UserPaymentMethod[]
  shoppingCart      ShoppingCart[]
  reviews           UserReview[]
  ShopOrder         ShopOrder[]
  promotions        Promotion[]
  products          Product[]
}

model UserRole {
  userId    String
  roleId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  users     UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Address {
  id        String        @id @default(uuid())
  street    String
  city      String
  state     String
  country   String
  zipCode   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  users     UserAddress[]
  ShopOrder ShopOrder[]
}

model UserAddress {
  userId    String
  addressId String
  isDefault Boolean  @default(false)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Address   Address  @relation(fields: [addressId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, addressId])
}

model Promotion {
  id         String              @id @default(uuid())
  userId     String
  code       String              @unique
  name       String
  discount   Float
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  categories PromotionCategory[]
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id                  String              @id @default(uuid())
  name                String              @unique
  parentId            String?
  parent              ProductCategory?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children            ProductCategory[]   @relation("CategoryHierarchy")
  promotionCategories PromotionCategory[]
  products            Product[]
  variations          Variation[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model PromotionCategory {
  categoryId  String
  promotionId String
  Category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  Promotion   Promotion       @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([categoryId, promotionId])
}

model Product {
  id            String          @id @default(uuid())
  categoryId    String
  createdBy     String
  name          String
  description   String
  category      ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdByUser User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  items         ProductItem[]
  images        ProductImage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ProductItem {
  id                   String                 @id @default(uuid())
  productId            String
  sku                  String                 @unique
  price                Float
  stock                Int
  images               ItemImage[]
  product              Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  ProductConfiguration ProductConfiguration[]
  ShoppingCartItem     ShoppingCartItem[]
  OrderLine            OrderLine[]
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ItemImage {
  id        String      @id @default(uuid())
  itemId    String
  url       String
  item      ProductItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Variation {
  id         String            @id @default(uuid())
  categoryId String
  name       String
  category   ProductCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options    VariationOption[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model VariationOption {
  id                   String                 @id @default(uuid())
  variationId          String
  value                String
  variation            Variation              @relation(fields: [variationId], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  ProductConfiguration ProductConfiguration[]
}

model ProductConfiguration {
  productItemId      String
  productVariationId String
  ProductItem        ProductItem     @relation(fields: [productItemId], references: [id], onDelete: Cascade)
  VariationOption    VariationOption @relation(fields: [productVariationId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([productItemId, productVariationId])
}

model PaymentType {
  id                String              @id @default(uuid())
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  UserPaymentMethod UserPaymentMethod[]
  ShopOrder         ShopOrder[]
}

model UserPaymentMethod {
  id             String      @id @default(uuid())
  userId         String
  paymentTypeId  String
  provider       String
  accountNumber  String
  expirationDate DateTime
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  User           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  PaymentType    PaymentType @relation(fields: [paymentTypeId], references: [id], onDelete: Cascade)
}

model ShoppingCartItem {
  id            String       @id @default(uuid())
  cartId        String
  productItemId String
  quantity      Int
  productItem   ProductItem  @relation(fields: [productItemId], references: [id], onDelete: Cascade)
  shoppingCart  ShoppingCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model ShoppingCart {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShoppingCartItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model UserReview {
  id               String    @id @default(uuid())
  userId           String
  orderedProductId String
  ratingValue      Int
  comment          String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  User             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  OrderLine        OrderLine @relation(fields: [orderedProductId], references: [id], onDelete: Cascade)
}

model OrderLine {
  id            String       @id @default(uuid())
  productItemId String
  orderId       String
  quantity      Int
  price         Float
  UserReview    UserReview[]
  productItem   ProductItem  @relation(fields: [productItemId], references: [id], onDelete: Cascade)
  ShopOrder     ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ShippingMethod {
  id        String      @id @default(uuid())
  name      String
  price     Float
  ShopOrder ShopOrder[]
}

model OrderStatus {
  id             String               @id @default(uuid())
  name           String
  ShopOrder      ShopOrder[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  OrderStatusLog ShopOrderStatusLog[]
}

model ShopOrder {
  id                 String               @id @default(uuid())
  userId             String
  orderDate          DateTime             @default(now())
  paymentMethodId    String
  shoppingAddressId  String
  shoppingMethodId   String
  orderTotal         Float
  orderStatusId      String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod      PaymentType          @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  shoppingAddress    Address              @relation(fields: [shoppingAddressId], references: [id], onDelete: Cascade)
  shoppingMethod     ShippingMethod       @relation(fields: [shoppingMethodId], references: [id], onDelete: Cascade)
  orderStatus        OrderStatus          @relation(fields: [orderStatusId], references: [id], onDelete: Cascade)
  orderLines         OrderLine[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ShopOrderStatusLog ShopOrderStatusLog[]
}

model ShopOrderStatusLog {
  id          String      @id @default(uuid())
  orderId     String
  statusId    String
  changedAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  ShopOrder   ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  OrderStatus OrderStatus @relation(fields: [statusId], references: [id], onDelete: Cascade)
}
